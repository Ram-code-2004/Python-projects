from plyer import notification
import time
def main():
    name = input("Enter your name for the water drinking reminder: ")
    if not name:
        name = "User"
    text = f"It's time to drink water! {name}"
def remind_to_drink_water():
    notification.notify(
        title="Water Drinking Reminder",
        message="It's time to drink water! Stay hydrated.",
        app_name="Water Drinking Reminder",
        timeout=10
    )
drink = remind_to_drink_water
try:
 while True:
    drink()
    time.sleep(3600)  # Remind every hour
except KeyboardInterrupt:
    print("Water drinking reminder stopped.")

